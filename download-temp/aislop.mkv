commandMetadata":{"webCommandMetadata":{"url":"https://support.google.com/youtube/answer/12257682?nohelpkit=1","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://support.google.com/youtube/answer/12257682?nohelpkit=1","target":"TARGET_NEW_WINDOW"}}},{"text":"\n\nYouTube is not responsible for merchant products or for the product information provided by merchants. YouTube is also not responsible for your activities and purchases made from merchants (including through the links below) which are governed by the respective merchant's terms and conditions (including their Privacy Policy). YouTube may share information with our partners to perform services, in compliance with our Privacy Policy and other appropriate confidentiality and security measures. For instance, YouTube may share your IP address with the merchant platform to facilitate the transaction. Product reviews are available in select locations only and are not verified by Google. ","textColor":4279440147},{"text":"Learn more","navigationEndpoint":{"clickTrackingParams":"CCYQx1UiEwjlyM-3grGUAxVZdMIBHcRlFnjKAQQ9t74C","commandMetadata":{"webCommandMetadata":{"url":"https://support.google.com/googleshopping/answer/9370999?nohelpkit=1","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://support.google.com/googleshopping/answer/9370999?nohelpkit=1","target":"TARGET_NEW_WINDOW"}}}]},"confirmLabel":{"simpleText":"OK"},"trackingParams":"CCYQx1UiEwjlyM-3grGUAxVZdMIBHcRlFng="}},"popupType":"DIALOG"}},"trackingParams":"CCQQlPQBGAEiEwjlyM-3grGUAxVZdMIBHcRlFng="}},{"menuServiceItemRenderer":{"text":{"accessibility":{"accessibilityData":{"label":"Report listing"}},"simpleText":"Report listing"},"icon":{"iconType":"FLAG"},"serviceEndpoint":{"clickTrackingParams":"CCUQ1tgHGAYiEwjlyM-3grGUAxVZdMIBHcRlFnjKAQQ9t74C","commandMetadata":{"webCommandMetadata":{"url":"https://accounts.google.com/ServiceLogin?service=youtube\u0026uilel=3\u0026passive=true\u0026continue=https%3A%2F%2Fwww.youtube.com%2Fsignin%3Faction_handle_signin%3Dtrue%26app%3Ddesktop%26hl%3Den\u0026hl=en","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"signInEndpoint":{"nextEndpoint":{"clickTrackingParams":"CCUQ1tgHGAYiEwjlyM-3grGUAxVZdMIBHcRlFnjKAQQ9t74C","commandMetadata":{"webCommandMetadata":{"sendPost":true,"apiUrl":"/youtubei/v1/flag/get_form"}},"getReportFormEndpoint":{"params":"%3D"}}}},"trackingParams":"CCUQ1tgHGAYiEwjlyM-3grGUAxVZdMIBHcRlFng=","loggingDirectives":{"trackingParams":"CCUQ1tgHGAYiEwjlyM-3grGUAxVZdMIBHcRlFng=","visibility":{"types":"15"},"gestures":{"types":"4"}}}}],"menuPopupAccessibility":{"label":"Actions menu"}}},"popupType":"DROPDOWN"}}}]}}},{"expandableVideoDescriptionBodyRenderer":{"showMoreText":{"accessibility":{"accessibilityData":{"label":"Show more"}},"simpleText":"...more"},"showLessText":{"simpleText":"Show less"},"attributedDescriptionBodyText":{"content":"Sources \u0026 further reading:\nhttps://sites.google.com/view/sources...\n\nAI-generated content is flooding the internet, from videos and music to news and books. On top of that, generative AI is making false information look more convincing than ever. \nWe're entering a new era of information overload, and figuring out what's real and what's not is becoming more and more of a challenge. While AI slop is slowly changing the internet as we know it, one thing is certain: kurzgesagt videos will always remain human-made.\n\n\nOUR CHANNELS\n▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀\nGerman:        https://kgs.link/youtubeDE\nSpanish:        https://kgs.link/youtubeES\nFrench:          https://kgs.link/youtubeFR\nPortuguese:  https://kgs.link/youtubePT\nArabic:           https://kgs.link/youtubeAR\nHindi:             https://kgs.link/youtubeHI\nJapanese:     https://kgs.link/youtubeJA\nKorean:          https://kgs.link/youtubeKO\n\n\nHOW CAN YOU SUPPORT US?\n▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀\nThis is how we make our living and it would be a pleasure if you support us!\n\nGet Products designed with ❤️ https://shop.kgs.link\nJoin the Patreon Bird Army 🐧  https://kgs.link/patreon  \n\n\nDISCUSSIONS \u0026 SOCIAL MEDIA\n▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀\nInstagram:     https://kgs.link/instagram\nTikTok:           https://kgs.link/tiktok\nReddit:            https://kgs.link/reddit\nDiscord:          https://kgs.link/discord\nTwitter:           https://kgs.link/twitter\nBluesky:          https://kgs.link/bluesky\nFacebook:      https://kgs.link/facebook\nNewsletter:    https://kgs.link/newsletter\n\n\nOUR VOICE\n▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀\nThe kurzgesagt voice is from \nSteve Taylor:  https://kgs.link/youtube-voice\n\n\nOUR MUSIC ♬♪\n▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀\n700+ minutes of kurzgesagt soundtracks by Epic Mountain:\n\nSpotify:            https://kgs.link/music-spotify\nSoundcloud:   https://kgs.link/music-soundcloud\nBandcamp:     https://kgs.link/music-bandcamp\nYoutube:          https://kgs.link/music-youtube\nFacebook:       https://kgs.link/music-facebook\n\nThe soundtrack of this video:\nSoundCloud: https://bit.ly/4nwF6XT\nBandcamp: https://bit.ly/42oSrJs\n\nIf you want to help us caption this video, please send subtitles to subtitle@kurzgesagt.org\nYou can find info on what subtitle files work on YouTube here:\nhttps://support.google.com/youtube/an...\nThank you!\n\n\n🐦🐧🐤 PATREON BIRD ARMY 🐤🐧🐦\n▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀\nMany thanks to our wonderful Patreons (from http://kgs.link/patreon) who support us every month and made this video possible:\nAlbie, AWhiskyDoc, Björn Simon, Bryan Maher, Calm_Sambonator, Delta Lead, Diana Lopez, Ektus, Elizabeth Dreghorn, Emily Vance, Endless Circuit, Gamtional Treasure, GTA Trolling, Hauke kaerkes, \nIan Watkins, Jade Jenner, Jakub, Jinxies Juice, Jonas K, Laura Wilkinson, Lizzie, Nebula, Panzer_43, Rich, Tigo Middelkoop, Toasti Mosti","commandRuns":[{"startIndex":27,"length":40,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBUQ040EGAkiEwjlyM-3grGUAxVZdMIBHcRlFnhIzfq-zvC-85v_AcoBBD23vgI=","commandMetadata":{"w